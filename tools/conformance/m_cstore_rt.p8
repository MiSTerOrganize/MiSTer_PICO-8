pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
-- conformance cart: cstore()/reload() ROM round-trip must be LOSSLESS.
-- pokes a deterministic pattern over the whole ROM data range
-- (0x0000-0x42ff = gfx/map/gff/song/sfx), cstores it into this cart's
-- own file, wipes ram, reloads, and checksums each region pre/post.
-- guards the .p8 save-serializer bug class: the sfx note writer used to
-- drop every custom-instrument flag (bit 15) on save, so one cstore()
-- permanently corrupted data packed in the sfx region (virtua racing's
-- track geometry -> the mister 'shattered track', root-caused
-- 2026-07-22, fixed in 2b638b6). the poke pattern cycles all 256 byte
-- values so every note field bit -- custom included -- is exercised.
function _v(l,v)
 printh("CONFVAL "..l.."="..tostr(v,true))
end

local regions={
 {"gfx",0x0000,0x1fff},
 {"map",0x2000,0x2fff},
 {"gff",0x3000,0x30ff},
 {"song",0x3100,0x31ff},
 {"sfx",0x3200,0x42ff}
}

local function rck(a0,a1)
 local c,i=0,0
 for a=a0,a1 do
  i+=1
  c=band(c+peek(a)*((i%13)+1),0x7fff)
 end
 return c
end

-- deterministic pattern over the whole rom data range
for a=0x0000,0x42ff do
 poke(a,(a*7+3)%256)
end

local pre={}
for _,r in ipairs(regions) do
 pre[r[1]]=rck(r[2],r[3])
end

-- store rom data into this cart's own file (the classic multicart
-- pattern -- exactly what virtua racing does to its data carts)
cstore(0x0000,0x0000,0x4300,"m_cstore_rt.p8")

-- wipe, then read it back through the save/load round trip
for a=0x0000,0x42ff do
 poke(a,0)
end
reload(0x0000,0x0000,0x4300,"m_cstore_rt.p8")

local ok=true
for _,r in ipairs(regions) do
 local post=rck(r[2],r[3])
 _v(r[1].."_pre",pre[r[1]])
 _v(r[1].."_post",post)
 if(post~=pre[r[1]]) ok=false
end
_v("roundtrip",ok and 1 or 0)
